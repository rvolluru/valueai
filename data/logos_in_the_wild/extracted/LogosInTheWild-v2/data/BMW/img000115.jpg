                                        <section class="content_content" id="CONTENT_fb2827df435a4cc78c08f10b1d8d6376">
         <div class="container-fluid px-0 banner-homepage-v3">
    <div class="row g-0 w-100 banner-box">
        <div class="col-12">
            <div class="container">
            <div class="row">
                <div class="col-12 col-lg-6 content-wrapper">
                    <!--start content left-->
                    <div class="container">
                        <div class="row g-0 d-flex justify-content-end">
                        <div class="col-12 content left">
                            <div class="quick-find-form">
                                <h2>Skip the Stress. Enjoy the Drive.</h2>
<p>The car buying service that helped thousands of Australians get their brand-new car, <b>hassle-free</b>. Let's get you on the road.</p>
  <div class="quick-find-form">
  
  <form>
      <div class="make-select-container">
          <label for="make">Make</label>
          <select class="form-control make-select" name="make" aria-label="Make">
              <option class="placeholder" disabled selected hidden>Make</option>
          </select>
      </div>

